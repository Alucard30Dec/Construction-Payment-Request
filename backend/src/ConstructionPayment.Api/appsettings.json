{
  "DatabaseProvider": "Sqlite",
  "Database": {
    "SeedDemoData": false,
    "AllowSqliteFallbackInDevelopment": true,
    "MySql": {
      "ServerVersion": "8.0.0-mysql",
      "ConnectionTimeoutSeconds": 8,
      "DefaultCommandTimeoutSeconds": 30,
      "EfCommandTimeoutSeconds": 30,
      "MaxRetryCount": 2,
      "MaxRetryDelaySeconds": 2,
      "MinimumPoolSize": 0,
      "MaximumPoolSize": 20,
      "KeepaliveSeconds": 30
    }
  },
  "ConnectionStrings": {
    "SqliteConnection": "Data Source=app.db",
    "SqlServerConnection": "Server=localhost;Database=ConstructionPaymentDb;User Id=sa;Password=Your_password123;TrustServerCertificate=True;MultipleActiveResultSets=true",
    "MySqlConnection": "mysql://username:password@localhost:4000/test"
  },
  "Jwt": {
    "Key": "ChangeThisToAStrongSecretKeyAtLeast32Characters!",
    "Issuer": "ConstructionPayment.Api",
    "Audience": "ConstructionPayment.Frontend",
    "ExpiryMinutes": 480
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Storage": {
    "UploadPath": "uploads"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
